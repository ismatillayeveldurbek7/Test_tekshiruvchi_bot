    "bot.py": """import asyncio
import logging
from aiogram import Bot, Dispatcher
from aiogram.client.default import DefaultBotProperties
from config import Config
from handlers import start, admin, user

logging.basicConfig(level=logging.INFO)

async def main():
    bot = Bot(token=Config.BOT_TOKEN, default_bot_properties=DefaultBotProperties(parse_mode="HTML"))
    dp = Dispatcher()

    dp.include_router(start.router)
    dp.include_router(admin.router)
    dp.include_router(user.router)

    logging.info("Bot ishga tushdi!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())""",

    "database/db.py": """import sqlite3
import asyncio
import os

class Database:
    def __init__(self, db_path="database/omr_bot.db"):
        self.db_path = db_path
        os.makedirs(os.path.dirname(self.db_path), exist_ok=True)
        self._init_db()

    def _init_db(self):
        conn = sqlite3.connect(self.db_path)
        cursor = conn.cursor()
        cursor.execute(\"\"\"
            CREATE TABLE IF NOT EXISTS users (
                telegram_id INTEGER PRIMARY KEY,
                username TEXT,
                full_name TEXT,
                role TEXT DEFAULT 'user'
            )
        \"\"\")
        cursor.execute(\"\"\"
            CREATE TABLE IF NOT EXISTS exams (
                exam_id TEXT PRIMARY KEY,
                title TEXT,
                keys TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        \"\"\")
        cursor.execute(\"\"\"
            CREATE TABLE IF NOT EXISTS results (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                telegram_id INTEGER,
                exam_id TEXT,
                score INTEGER,
                total INTEGER,
                percentage REAL,
                correct_count INTEGER,
                wrong_count INTEGER,
                skipped_count INTEGER,
                checked_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        \"\"\")
        conn.commit()
        conn.close()

    async def execute(self, query, params=()):
        def _execute():
            conn = sqlite3.connect(self.db_path)
            cursor = conn.cursor()
            cursor.execute(query, params)
            conn.commit()
            res = cursor.fetchall()
            last_row_id = cursor.lastrowid
            conn.close()
            return res, last_row_id
        return await asyncio.to_thread(_execute)

db = Database()""",

    "states/states.py": """from aiogram.fsm.state import State, StatesGroup

class AdminStates(StatesGroup):
    waiting_for_exam_id = State()
    waiting_for_exam_title = State()
    waiting_for_exam_keys = State()

class UserStates(StatesGroup):
    selecting_exam = State()
    waiting_for_sheet = State()""",

    "keyboards/reply_kb.py": """from aiogram.types import ReplyKeyboardMarkup, KeyboardButton

def get_main_keyboard(is_admin: bool = False) -> ReplyKeyboardMarkup:
    buttons = [
        [KeyboardButton(text="Testni Tekshirish 📝"), KeyboardButton(text="Mening Natijalarim 📊")],
        [KeyboardButton(text="Peshqadamlar Imtihonlar 🏆"), KeyboardButton(text="Yordam ℹ️")]
    ]
    if is_admin:
        buttons.append([KeyboardButton(text="Admin Panel ⚙️")])
    return ReplyKeyboardMarkup(keyboard=buttons, resize_keyboard=True)

def get_admin_keyboard() -> ReplyKeyboardMarkup:
    return ReplyKeyboardMarkup(
        keyboard=[
            [KeyboardButton(text="Yangi Imtihon Qo'shish ➕"), KeyboardButton(text="Imtihonlarni Ko'rish 📋")],
            [KeyboardButton(text="Umumiy Statistika 📈"), KeyboardButton(text="Chiqish ⬅️")]
        ],
        resize_keyboard=True
    )""",

    "keyboards/inline_kb.py": """from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton

def get_exams_inline_markup(exams: list) -> InlineKeyboardMarkup:
    keyboard = []
    for exam in exams:
        keyboard.append([InlineKeyboardButton(text=exam[1], callback_data=f"exam_select:{exam[0]}")])
    return InlineKeyboardMarkup(inline_keyboard=keyboard)

def get_delete_exam_markup(exam_id: str) -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="O'chirish ❌", callback_data=f"exam_delete:{exam_id}")]
    ])""",

    "services/groq_service.py": """from groq import Groq
from config import Config

class GroqService:
    def __init__(self):
        self.client = None
        if Config.GROQ_API_KEY:
            self.client = Groq(api_key=Config.GROQ_API_KEY)

    async def get_exam_advice(self, score, total, percentage) -> str:
        if not self.client:
            return "Natijangiz muvaffaqiyatli saqlandi!"
        prompt = f"Foydalanuvchi imtihon topshirdi. Natija: {score} ta to'g'ri {total} tadan. Foizi: {percentage}%. Tavsiya bering (o'zbek tilida, maks 3 qator)."
        try:
            chat_completion = self.client.chat.completions.create(
                messages=[{"role": "user", "content": prompt}],
                model="llama3-8b-8192",
            )
            return chat_completion.choices[0].message.content.strip()
        except:
            return "Kelgusi imtihonlarda muvaffaqiyat tilaymiz! 🚀"

groq_service = GroqService()""",

    "omr_engine/analyzer.py": """import cv2
import numpy as np
import os

def analyze_omr_sheet(img_path, correct_answers):
    img = cv2.imread(img_path)
    if img is None:
        return None, "Tasvirni o'qib bo'lmadi."

    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)
    blurred = cv2.GaussianBlur(gray, (5, 5), 0)
    edged = cv2.Canny(blurred, 75, 200)

    cnts, _ = cv2.findContours(edged.copy(), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    doc_cnt = None

    if len(cnts) > 0:
        cnts = sorted(cnts, key=cv2.contourArea, reverse=True)
        for c in cnts:
            peri = cv2.arcLength(c, True)
            approx = cv2.approxPolyDP(c, 0.02 * peri, True)
            if len(approx) == 4:
                doc_cnt = approx
                break

    if doc_cnt is not None:
        pts = doc_cnt.reshape(4, 2)
        rect = np.zeros((4, 2), dtype="float32")
        s = pts.sum(axis=1)
        rect[0] = pts[np.argmin(s)]
        rect[2] = pts[np.argmax(s)]
        diff = np.diff(pts, axis=1)
        rect[1] = pts[np.argmin(diff)]
        rect[3] = pts[np.argmax(diff)]

        (tl, tr, br, bl) = rect
        widthA = np.sqrt(((br[0] - bl[0]) ** 2) + ((br[1] - bl[1]) ** 2))
        widthB = np.sqrt(((tr[0] - tl[0]) ** 2) + ((tr[1] - tl[1]) ** 2))
        maxWidth = max(int(widthA), int(widthB))
        heightA = np.sqrt(((tr[0] - br[0]) ** 2) + ((tr[1] - br[1]) ** 2))
        heightB = np.sqrt(((tl[0] - bl[0]) ** 2) + ((tl[1] - bl[1]) ** 2))
        maxHeight = max(int(heightA), int(heightB))

        dst = np.array([[0, 0], [maxWidth - 1, 0], [maxWidth - 1, maxHeight - 1], [0, maxHeight - 1]], dtype="float32")
        M = cv2.getPerspectiveTransform(rect, dst)
        warped = cv2.warpPerspective(img, M, (maxWidth, maxHeight))
    else:
        warped = img.copy()

    warped = cv2.resize(warped, (600, 1200))
    warped_gray = cv2.cvtColor(warped, cv2.COLOR_BGR2GRAY)
    thresh = cv2.threshold(warped_gray, 0, 255, cv2.THRESH_BINARY_INV | cv2.THRESH_OTSU)[1]

    top_pad = 120
    row_h = (1200 - 180) / 35.0
    col_xs = [160, 245, 330, 415, 500]
    options_map = {0: 'A', 1: 'B', 2: 'C', 3: 'D', 4: 'E'}
    rev_options_map = {'A': 0, 'B': 1, 'C': 2, 'D': 3, 'E': 4}

    results = {}
    correct_count = 0
    wrong_count = 0
    skipped_count = 0

    annotated = warped.copy()
    total_active_questions = len(correct_answers)

    for q_idx in range(1, total_active_questions + 1):
        expected_ans = correct_answers.get(str(q_idx))
        if not expected_ans:
            continue

        row_y = int(top_pad + (q_idx - 1) * row_h + row_h / 2)
        bubble_scores = []
        for col_idx, cx in enumerate(col_xs):
            mask = np.zeros(thresh.shape, dtype="uint8")
            cv2.circle(mask, (cx, row_y), 11, 255, -1)
            mask = cv2.bitwise_and(thresh, mask)
            total_white = cv2.countNonZero(mask)
            bubble_scores.append(total_white)

        filled_cols = [idx for idx, score in enumerate(bubble_scores) if score >= 140]
        expected_col = rev_options_map.get(expected_ans)

        if len(filled_cols) == 0:
            results[q_idx] = {"status": "SKIPPED", "detected": None, "correct": expected_ans}
            skipped_count += 1
            if expected_col is not None:
                cv2.circle(annotated, (col_xs[expected_col], row_y), 14, (0, 165, 255), 2)
        elif len(filled_cols) > 1:
            detected_labels = [options_map[c] for c in filled_cols]
            results[q_idx] = {"status": "INVALID", "detected": detected_labels, "correct": expected_ans}
            wrong_count += 1
            for c in filled_cols:
                cv2.circle(annotated, (col_xs[c], row_y), 14, (0, 0, 255), 2)
            if expected_col is not None:
                cv2.circle(annotated, (col_xs[expected_col], row_y), 14, (0, 255, 0), 2)
        else:
            chosen_col = filled_cols[0]
            chosen_ans = options_map[chosen_col]
            if chosen_ans == expected_ans:
                results[q_idx] = {"status": "CORRECT", "detected": chosen_ans, "correct": expected_ans}
                correct_count += 1
                cv2.circle(annotated, (col_xs[chosen_col], row_y), 14, (0, 255, 0), 2)
            else:
                results[q_idx] = {"status": "WRONG", "detected": chosen_ans, "correct": expected_ans}
                wrong_count += 1
                cv2.circle(annotated, (col_xs[chosen_col], row_y), 14, (0, 0, 255), 2)
                if expected_col is not None:
                    cv2.circle(annotated, (col_xs[expected_col], row_y), 14, (0, 255, 0), 2)

    for q_idx in range(1, total_active_questions + 1):
        row_y = int(top_pad + (q_idx - 1) * row_h + row_h / 2)
        cv2.putText(annotated, f"{q_idx}.", (30, row_y + 5), cv2.FONT_HERSHEY_SIMPLEX, 0.45, (255, 255, 255), 1)

    score_percent = (correct_count / total_active_questions * 100) if total_active_questions > 0 else 0
    base, ext = os.path.splitext(img_path)
    output_path = f"{base}_analyzed{ext}"
    cv2.imwrite(output_path, annotated)

    summary = {
        "correct_count": correct_count,
        "wrong_count": wrong_count,
        "skipped_count": skipped_count,
        "score_percent": round(score_percent, 2),
        "total_questions": total_active_questions,
        "results": results,
        "output_image_path": output_path
    }
    return summary, None""",

    "handlers/start.py": """from aiogram import Router, F
from aiogram.filters import CommandStart
from aiogram.types import Message
from config import Config
from database.db import db
from keyboards.reply_kb import get_main_keyboard

router = Router()

@router.message(CommandStart())
async def start_handler(message: Message):
    user_id = message.from_user.id
    username = message.from_user.username
    full_name = message.from_user.full_name
    role = "admin" if user_id in Config.ADMIN_IDS else "user"
    
    await db.execute(\"\"\"
        INSERT OR REPLACE INTO users (telegram_id, username, full_name, role)
        VALUES (?, ?, ?, ?)
    \"\"\", (user_id, username, full_name, role))
    
    is_admin = user_id in Config.ADMIN_IDS
    await message.answer(
        f"Assalomu alaykum, {full_name}! 👋\\n\\nMen OMR Test tekshirish botiman.",
        reply_markup=get_main_keyboard(is_admin)
    )

@router.message(F.text == "Yordam ℹ️")
async def help_handler(message: Message):
    await message.answer("Tizimdan foydalanish uchun 'Testni Tekshirish' tugmasini bosing va OMR rasmini yuboring.")""",

    "handlers/admin.py": """from aiogram import Router, F
from aiogram.types import Message, CallbackQuery
from aiogram.fsm.context import FSMContext
from config import Config
from database.db import db
from states.states import AdminStates
from keyboards.reply_kb import get_admin_keyboard, get_main_keyboard
from keyboards.inline_kb import get_delete_exam_markup
import re
import json

router = Router()

def is_admin_filter(message: Message) -> bool:
    return message.from_user.id in Config.ADMIN_IDS

@router.message(F.text == "Admin Panel ⚙️", is_admin_filter)
async def admin_panel(message: Message):
    await message.answer("Boshqaruv paneli", reply_markup=get_admin_keyboard())

@router.message(F.text == "Chiqish ⬅️", is_admin_filter)
async def exit_admin(message: Message):
    await message.answer("Bosh menyu", reply_markup=get_main_keyboard(True))

@router.message(F.text == "Yangi Imtihon Qo'shish ➕", is_admin_filter)
async def start_add_exam(message: Message, state: FSMContext):
    await message.answer("Imtihon ID kiriting:")
    await state.set_state(AdminStates.waiting_for_exam_id)

@router.message(AdminStates.waiting_for_exam_id, is_admin_filter)
async def process_exam_id(message: Message, state: FSMContext):
    exam_id = message.text.strip().upper()
    await state.update_data(exam_id=exam_id)
    await message.answer("Imtihon nomini kiriting:")
    await state.set_state(AdminStates.waiting_for_exam_title)

@router.message(AdminStates.waiting_for_exam_title, is_admin_filter)
async def process_exam_title(message: Message, state: FSMContext):
    await state.update_data(title=message.text.strip())
    await message.answer("Javoblarni kiriting (masalan: ABCDE...):")
    await state.set_state(AdminStates.waiting_for_exam_keys)

@router.message(AdminStates.waiting_for_exam_keys, is_admin_filter)
async def process_exam_keys(message: Message, state: FSMContext):
    text = message.text.strip().upper()
    parsed_keys = {str(i+1): char for i, char in enumerate(text)} if text.isalpha() else {}
    if not parsed_keys:
         await message.answer("Xato format. Qayta urinib ko'ring:")
         return
    data = await state.get_data()
    await db.execute("INSERT INTO exams (exam_id, title, keys) VALUES (?, ?, ?)", (data['exam_id'], data['title'], json.dumps(parsed_keys)))
    await state.clear()
    await message.answer("Saqlandi!", reply_markup=get_admin_keyboard())

@router.message(F.text == "Imtihonlarni Ko'rish 📋", is_admin_filter)
async def list_exams(message: Message):
    exams = await db.execute("SELECT exam_id, title FROM exams")
    if not exams[0]:
        await message.answer("Imtihonlar mavjud emas.")
        return
    for exam in exams[0]:
        await message.answer(f"ID: {exam[0]}\\nNomi: {exam[1]}", reply_markup=get_delete_exam_markup(exam[0]))

@router.callback_query(F.data.startswith("exam_delete:"))
async def delete_exam_cb(callback: CallbackQuery):
    exam_id = callback.data.split(":")[1]
    await db.execute("DELETE FROM exams WHERE exam_id = ?", (exam_id,))
    await callback.answer("O'chirildi")
    await callback.message.delete()""",

    "handlers/user.py": """from aiogram import Router, F, Bot
from aiogram.types import Message, CallbackQuery, FSInputFile
from aiogram.fsm.context import FSMContext
from database.db import db
from states.states import UserStates
from keyboards.inline_kb import get_exams_inline_markup
from omr_engine.analyzer import analyze_omr_sheet
from services.groq_service import groq_service
import json
import os

router = Router()

@router.message(F.text == "Testni Tekshirish 📝")
async def user_check_test(message: Message, state: FSMContext):
    exams = await db.execute("SELECT exam_id, title FROM exams")
    if not exams[0]:
        await message.answer("Faol imtihonlar yo'q.")
        return
    await message.answer("Imtihonni tanlang:", reply_markup=get_exams_inline_markup(exams[0]))
    await state.set_state(UserStates.selecting_exam)

@router.callback_query(UserStates.selecting_exam, F.data.startswith("exam_select:"))
async def exam_selected(callback: CallbackQuery, state: FSMContext):
    exam_id = callback.data.split(":")[1]
    await state.update_data(exam_id=exam_id)
    await callback.message.answer("Endi OMR rasmini yuboring:")
    await state.set_state(UserStates.waiting_for_sheet)
    await callback.answer()

@router.message(UserStates.waiting_for_sheet, F.photo)
async def process_omr_sheet(message: Message, state: FSMContext, bot: Bot):
    data = await state.get_data()
    exam_id = data.get("exam_id")
    exam_res = await db.execute("SELECT title, keys FROM exams WHERE exam_id = ?", (exam_id,))
    correct_answers = json.loads(exam_res[0][0][1])
    
    photo = message.photo[-1]
    os.makedirs("temp", exist_ok=True)
    temp_path = f"temp/{message.from_user.id}_{photo.file_id}.jpg"
    await bot.download(photo, destination=temp_path)
    
    summary, err = analyze_omr_sheet(temp_path, correct_answers)
    if err:
        await message.answer(f"Xato: {err}")
        return

    await db.execute(\"\"\"
        INSERT INTO results (telegram_id, exam_id, score, total, percentage, correct_count, wrong_count, skipped_count)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?)
    \"\"\", (message.from_user.id, exam_id, summary["correct_count"], summary["total_questions"], summary["score_percent"], summary["correct_count"], summary["wrong_count"], summary["skipped_count"]))

    ai_advice = await groq_service.get_exam_advice(summary["correct_count"], summary["total_questions"], summary["score_percent"])

    result_text = (
        f"📝 {exam_res[0][0][0]}\\n\\n"
        f"✅ To'g'ri: {summary['correct_count']}\\n"
        f"❌ Noto'g'ri: {summary['wrong_count']}\\n"
        f"📊 Foiz: {summary['score_percent']}%\\n\\n"
        f"🤖 AI: {ai_advice}"
    )

    await message.answer_photo(photo=FSInputFile(summary["output_image_path"]), caption=result_text)
    
    if os.path.exists(temp_path): os.remove(temp_path)
    if os.path.exists(summary["output_image_path"]): os.remove(summary["output_image_path"])
    await state.clear()"""
}

# Fayllarni yozish
for file_path, content in files_data.items():
    dir_name = os.path.dirname(file_path)
    if dir_name:
        os.makedirs(dir_name, exist_ok=True)
    with open(file_path, "w", encoding="utf-8") as f:
        f.write(content)

# ZIP arxiv yaratish
zip_filename = "omr_bot.zip"
with zipfile.ZipFile(zip_filename, 'w', zipfile.ZIP_DEFLATED) as zipf:
    for root, dirs, files in os.walk("."):
        # create_zip.py faylining o'zini va mavjud .db fayllarini zipga qo'shmaymiz
        if "create_zip.py" in files:
            files.remove("create_zip.py")
        if "omr_bot.db" in files:
            files.remove("omr_bot.db")
        if zip_filename in files:
            files.remove(zip_filename)
        for file in files:
            file_p = os.path.join(root, file)
            # Nuqta bilan boshlanadigan ichki papkalarni (.git kabi) o'tkazib yuborish
            if not any(part.startswith('.') for part in file_p.split(os.sep) if part != '.'):
                zipf.write(file_p, os.path.relpath(file_p, "."))

print(f"Muvaffaqiyatli yakunlandi! '{zip_filename}' fayli yaratildi.")
